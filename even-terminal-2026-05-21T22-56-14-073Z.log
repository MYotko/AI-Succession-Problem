naway threshold."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1429,"cache_read_input_tokens":57598,"cache_creation":{"ephemeral_5m_input_tokens":1429,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"14de45e0-5c35-4a29-8902-323cddebae7f","uuid":"b80767c3-11a1-44f3-9833-4a22a1308917"}
