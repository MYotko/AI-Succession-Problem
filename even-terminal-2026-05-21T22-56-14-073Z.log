:{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":44262,"cache_read_input_tokens":11442,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":44262},"output_tokens":30,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"14de45e0-5c35-4a29-8902-323cddebae7f","uuid":"01283a9d-62f0-4d1e-b595-5a2ccfbcaa4a"}
