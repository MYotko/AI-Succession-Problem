[2026-05-22 17:17:56] [claude-sdk] {"type":"stream_event","event":{"type":"content_block_delta","index":1,"delta":{"type":"text_delta","text":". Worth noting in the spec gaps."}},"session_id":"14de45e0-5c35-4a29-8902-323cddebae7f","parent_tool_use_id":null,"uuid":"c1d37b9e-130f-421a-a0bd-c58249d84553"}
